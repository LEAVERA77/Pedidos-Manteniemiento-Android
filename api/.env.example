PORT=3000
DB_CONNECTION=postgresql://usuario:password@host/neondb?sslmode=require
JWT_SECRET=cambiar_en_produccion
JWT_EXPIRES_IN=24h

# Multitenant: JWT incluye tenant_id; el host (subdominio) debe coincidir con la sesión.
# ENFORCE_TENANT_HOST=true + GESTORNOVA_TENANT_HOST_SUFFIXES=.gestornova.com
ENFORCE_TENANT_HOST=false
GESTORNOVA_TENANT_HOST_SUFFIXES=
# Hosts de la API (p. ej. tu-servicio.onrender.com) cuando el cliente llama sin subdominio en Host.
# Ej. admin en GitHub Pages contra API en Render: nexxo-api-418k.onrender.com
TENANT_HOST_FALLBACK_ALLOW_HOSTS=
# Alta de fila en clientes vía POST /api/clientes (opcional): header X-Platform-Signup igual a este secreto.
PLATFORM_TENANT_SIGNUP_SECRET=
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
# Coma-separado. Orígenes permitidos para frontend web (CORS).
CORS_ALLOWED_ORIGINS=https://leavera77.github.io,http://localhost:5173,http://localhost:3000

# Webhook Evolution API / WAHA / Whapi → POST /api/webhooks/whatsapp/evolution|waha|whapi
# Query ?token=... o header Authorization: Bearer ...
# Con WAHA local: mismo valor que WHATSAPP_WEBHOOK_TOKEN en compose.waha.env (raíz del repo)
# Secreto que definís vos para ?token= en la URL del webhook (Whapi: misma cadena que en el panel).
# Whapi también puede mandar Bearer WHAPI_API_KEY; la ruta /whapi lo acepta además de este token.
WHATSAPP_WEBHOOK_TOKEN=
# Si 1/true: POST /whapi loguea JSON crudo (truncado). Solo diagnóstico; en prod estable usar 0 o vacío.
WHATSAPP_WEBHOOK_DEBUG=

# ── Proveedor WhatsApp (nombre exacto de variable: WHATSAPP_PROVIDER — ver api/services/whatsappService.js) ──
# Valores: whapi | meta | waha | evolution
# Si no definís la variable, el código usa "meta" por defecto; esta plantilla asume Whapi en campo/producción actual.
# Guía cambio de proveedor: api/docs/CAMBIAR_PROVEEDOR_WHATSAPP.md
WHATSAPP_PROVIDER=whapi
# Whapi.cloud — envío y webhook /api/webhooks/whatsapp/whapi (HTTPS público en Render)
WHAPI_API_URL=https://gate.whapi.cloud
WHAPI_API_KEY=
# Opcional: Channel ID del panel (ej. MANTIS-xxxxx) → tenant sin depender de META_PHONE_NUMBER_ID
WHAPI_CHANNEL_ID=
# Opcional: fuerza phone_number_id en el adaptador Whapi
# WHAPI_META_PHONE_NUMBER_ID=
# Con Whapi en Render: webhook HTTPS `https://<tu-host>/api/webhooks/whatsapp/whapi?token=<WHATSAPP_WEBHOOK_TOKEN>` (mismo token que arriba).

# Solo si WHATSAPP_PROVIDER=evolution — mismo valor que AUTHENTICATION_API_KEY en docker-compose.evolution.yml
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=gestornova-evolution-2026
# EVOLUTION_INSTANCE=gestornova
# Solo si WHATSAPP_PROVIDER=waha — docker-compose.waha.yml (puerto host 3080 → contenedor 3000)
# WAHA_API_URL=http://localhost:3080
# WAHA_API_KEY=gestornova-waha-2026
# WAHA_SESSION=default
# (WAHA Core solo permite "default"; nombres custom → WAHA Plus)
# Solo para npm run waha:pair — tu número en dígitos (ej. 549XXXXXXXXXX)
# WAHA_PAIR_PHONE=

# ── Meta WhatsApp Cloud API (usar cuando WHATSAPP_PROVIDER=meta; NUNCA commitear secretos) ──
# Callback URL en Meta Developers → tu app → WhatsApp → Configuration:
#   https://<tu-servicio>.onrender.com/api/webhooks/whatsapp/meta
# Suscripción: messages (y status si lo usás).
# El "Verify token" del panel debe coincidir exactamente con META_WEBHOOK_VERIFY_TOKEN.
# El body llega como JSON; la firma va en X-Hub-Signature-256 (HMAC SHA256 con META_APP_SECRET).
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
# Caduca según lo definido en Meta (sesiones cortas ~24h; tokens largos según configuración).
# Si en logs ves OAuthException code 190 / subcode 463: renovar token y volver a pegar aquí / en Render.
META_ACCESS_TOKEN=
# Debe coincidir con el número que recibe los mensajes (mismo ID que en el webhook).
# Multitenant: en Neon, clientes.configuracion (JSONB) puede incluir meta_access_token y meta_phone_id por tenant (además de estas variables globales). Ver docs/NEON_meta_whatsapp_phone_id.sql.
META_PHONE_NUMBER_ID=
# Identificador de la cuenta WhatsApp Business (WABA) en Business Manager. No reemplaza a META_PHONE_NUMBER_ID en Graph.
# Opcional: logs de envío y validación de que entry.id del webhook coincide con tu cuenta (mismo valor que en API Setup).
META_WABA_ID=
# Solo bot (webhook Meta): quién gana si Neon tiene meta_phone_id igual al webhook.
# db_first (default): clientes.configuracion.meta_access_token en Neon gana sobre META_ACCESS_TOKEN de Render.
# env_first: si META_PHONE_NUMBER_ID coincide con el webhook y META_ACCESS_TOKEN no está vacío, usa Render antes que Neon.
# WHATSAPP_META_BOT_CREDENTIALS_ORDER=db_first
# WHATSAPP_META_BOT_CREDENTIALS_ORDER=env_first
# Opcional alias: META_WHATSAPP_BOT_CREDENTIALS_ORDER
# Opcional (default v21.0). Si Graph devuelve error de versión, probá v20.0
META_GRAPH_API_VERSION=v21.0
# Solo desarrollo local con @whatsapp-cloudapi/emulator: base del emulador (sin / final). NO definir en Render.
# El emulador actual solo acepta Graph API v24.0 → en .env local usá también META_GRAPH_API_VERSION=v24.0
# META_GRAPH_URL=http://localhost:4004
# Puerto del emulador (opcional, default 4004)
# WHATSAPP_EMULATOR_PORT=4004
# URL base donde corre la API (webhook del emulador). Default http://localhost:3000
# EMULATOR_WEBHOOK_API_BASE=http://localhost:3000
# Solo depuración: si la firma falla pero querés procesar igual (no usar en prod).
META_ALLOW_INVALID_SIGNATURE=false
# Argentina / sandbox Meta: webhook 549… → Graph con 543… (quita el 9 tras 54). Evita 131030 en desarrollo.
# Desactivar strip solo con: false | 0 | no | off
META_WHATSAPP_ARGENTINA_STRIP_MOBILE_9=true
# Outbound Graph: reinsertar 9 (543…→549…) solo si tu entorno productivo lo exige. En Meta **sandbox** dejar **false**
# (default) para que `to` coincida con la lista de prueba (evita 131030). Ver README api/README.md sección Meta.
META_WHATSAPP_ARGENTINA_INSERT_MOBILE_9=false

# Bot conversacional (menú / pedidos por WhatsApp). "Hola" responde aunque esté desactivado el menú.
WHATSAPP_BOT_ENABLED=true
# Si está en false/0/off, nadie puede activar el bot solo por WhatsApp (corte duro en servidor).
# Con el bot habilitado por env: interruptor persistente en BD (migración api/db/migrations/global_bot_state.sql).
# Comandos (primera palabra, sin acentos): activar | desactivar — solo desde número(s) en WHATSAPP_BOT_MASTER_PHONE(S) (dígitos, coma-separado).
# Cada entrada debe tener al menos 8 dígitos (si no, se ignora y no bloquea el fallback).
# Además del MASTER válido: también se acepta si coincide el teléfono del admin en Neon (telefono / whatsapp_notificaciones), misma regla 549/54 que el webhook.
WHATSAPP_BOT_MASTER_PHONE=
# WHATSAPP_BOT_MASTER_PHONES=5491112345678,5491198765432
WHATSAPP_BOT_TENANT_ID=1
# Opcional: código de distribuidor por defecto al crear pedido desde el bot
WHATSAPP_BOT_DISTRIBUIDOR_CODIGO=
# Si no hay admin ni ningún usuario activo en el tenant y pedidos.usuario_id es NOT NULL: ID de usuario (cualquier rol) para asignar como creador del pedido del bot
WHATSAPP_BOT_FALLBACK_USUARIO_ID=
# Si true/1: no usar coords de socios_catalogo marcadas como manuales (PASO 2); sigue Nominatim/pipeline. Útil si hay pins viejos mal ubicados hasta corregir catálogo.
# IGNORAR_CATALOGO_MANUAL=false
# Catálogo: ignorar filas con coordenada_sospechosa=TRUE (tras migración add_socios_catalogo_coord_auditoria.sql)
# IGNORAR_COORDENADAS_SOSPECHOSAS=false
# Catálogo: no usar coords cuya fecha_actualizacion_coords sea anterior a esta fecha ISO (requiere columna fecha_actualizacion_coords)
# IGNORAR_CATALOGO_FECHA=
# Catálogo: si fecha_actualizacion_coords tiene más de N días, no priorizar PASO 2 (0 = desactivado)
# MAX_EDAD_COORDS_CATALOGO_DIAS=0
# Catálogo: si no es "false", el pipeline ignora coords cercanas a puntos genéricos conocidos (lista en sociosCatalogoCoordsValidacion.js)
# IGNORAR_PUNTOS_KNOWN_BAD_CATALOGO=true
# Al guardar coords en socios_catalogo: bloquear si caen en punto sospechoso conocido
# CATALOGO_BLOQUEAR_PUNTOS_SOSPECHOSOS=false
# Al guardar: rechazar si coords fuera del bbox de la provincia del pedido (estricto)
# CATALOGO_BLOQUEAR_FUERA_BBOX_PROVINCIA=false

# Nominatim: origen HTTP (sin / al final). Sin variable → instancia propia por defecto en código (VPS); para API pública: NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# NOMINATIM_BASE_URL=http://45.76.3.146:8080
# Si la instancia propia falla o devuelve [], reintentar en OSM público (desactivar: NOMINATIM_PUBLIC_FALLBACK=false)
# NOMINATIM_PUBLIC_FALLBACK=true
# URL alternativa de fallback (opcional)
# NOMINATIM_PUBLIC_FALLBACK_URL=https://nominatim.openstreetmap.org
# User-Agent y contacto — política https://operations.osmfoundation.org/policies/nominatim/
# NOMINATIM_USER_AGENT=
# Si definís NOMINATIM_FROM_EMAIL o NOMINATIM_FROM, se envía cabecera From (recomendado en producción).
# Sin ellos, no se envía From (evita 406 en algunos proxy; el UA sigue identificando la app).
# NOMINATIM_FROM_EMAIL=
# Opcional: cabecera Accept (default */*)
# NOMINATIM_ACCEPT=*/*
# Desactivar segundo intento tras HTTP 406 (cabeceras mínimas): NOMINATIM_DISABLE_406_RETRY=1
# NOMINATIM_DISABLE_406_RETRY=
# Timeout por request (ms), default 15000
# NOMINATIM_FETCH_TIMEOUT_MS=15000
# Reintentos si Nominatim responde 429/503 (default 4)
# NOMINATIM_RATE_LIMIT_RETRIES=4
# Caché en memoria de búsquedas free-form idénticas (proceso Node)
# NOMINATIM_ENABLE_CACHE=true
# NOMINATIM_CACHE_TTL_DAYS=7
# NOMINATIM_CACHE_TTL_MS=
# WhatsApp / Simple-q: free-form (default) usa búsqueda tipo UI web; structured = solo geocodeAddressArgentina (q + filtros legacy)
# NOMINATIM_WHATSAPP_SEARCH_MODE=free-form
# Fallbacks extra (sin número / ciudad) tras free-form
# NOMINATIM_ENABLE_FALLBACKS=true
# Tras fallar geocodificación con número: intentar punto en la vía vía Nominatim sin puerta (centro de calle aproximado). Default activo.
# NOMINATIM_FALLBACK_CENTRO_CALLE=true
# Si el número exacto no está en OSM: buscar el mismo eje con números de la misma paridad (±2, ±4, …). Desactivar: false|0
# NOMINATIM_BUSCAR_NUMERO_CERCANO=true
# Máx. “saltos” de paridad (cada salto ±2 en el número); también acepta NOMINATIM_HOUSE_PARITY_MAX_STEPS si MAX_DISTANCIA no está definido (default 8, máx. 40)
# NOMINATIM_MAX_DISTANCIA_NUMEROS=20
# NOMINATIM_HOUSE_PARITY_MAX_STEPS=8
# Primera pasada free-form sin countrycodes=ar (mejor paridad con nominatim.openstreetmap.org/ui); desactivar: false
# NOMINATIM_FREEFORM_OMIT_COUNTRYCODES_FIRST=true
# Log de URLs/respuestas (solo diagnóstico)
# DEBUG_NOMINATIM=false
# Router /api/debug/* — en NODE_ENV=production responde 404 salvo que pongas explícitamente:
# ALLOW_DEBUG_ENDPOINTS=true
# (En desarrollo, los debug están habilitados salvo ALLOW_DEBUG_ENDPOINTS=false)
# ALLOW_DEBUG_ENDPOINTS=false
# GET /api/debug/nominatim-test — si el router está habilitado: desactivar endpoint con ALLOW_DEBUG_NOMINATIM=0
# ALLOW_DEBUG_NOMINATIM=
# INSERT pedido WhatsApp: log cols/vals y coords tras RETURNING (ver también DEBUG_WA_COORDS)
# WA_INSERT_DEBUG=true
# DEBUG_WA_COORDS=1
# Georef (API nacional datos.gob.ar) — respaldo si Nominatim no devuelve punto; desactivar: false
# GEO_REF_AR_ENABLED=true
# GEO_REF_FETCH_TIMEOUT_MS=12000
# Tabla correcciones_direcciones (overrides manuales); desactivar: false
# CORRECCIONES_DIRECCIONES_ENABLED=true
# Overpass — interpolación por geometría / addr:housenumber (PASO 3e, antes de interpolación municipal)
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter
# OVERPASS_TIMEOUT_MS=10000
# Pausa entre variantes de nombre de calle (reduce 429). Default 2000 ms.
# OVERPASS_GAP_BETWEEN_QUERIES_MS=2000
# Reintentos ante HTTP 429/502/503/504 (default 5)
# OVERPASS_MAX_RETRIES=5
# NOMINATIM_INTERPOLACION_CALLE=true
# NOMINATIM_INTERPOLACION_MAX_DISTANCIA=50
# Geocodificación catastral (PASO 3f: cadena sobre geometría cacheada + offset lateral). Requiere migración calles_geometrias.sql en Neon.
# CATASTRAL_GEOCODING_ENABLED=true
# CATASTRAL_OFFSET_LATERAL_METROS=5
# Por defecto el número de puerta se interpreta como metros desde el origen de la nomenclatura. Si preferís “cuadras” (número × metros por cuadra):
# CATASTRAL_NUMERO_COMO_CUADRA=false
# CATASTRAL_METROS_POR_CUADRA=100
# Geocódigo bot por padrón: en clientes.configuracion (JSON) definir "provincia" o "state" (ej. Entre Ríos) para desambiguar localidades homónimas.
# Opcional — índice local de domicilios (JSON o CSV) para reforzar cobertura sin APIs de pago. Sin archivo: solo Nominatim.
# LOCAL_ADDRESS_INDEX_PATH=/ruta/a/domicilios.json

# Rate limiting (express-rate-limit) — IP detrás de proxy (Render: TRUST_PROXY_COUNT=1)
# TRUST_PROXY_COUNT=1
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=5
# RATE_LIMIT_GEOCODE_WINDOW_MS=60000
# RATE_LIMIT_GEOCODE_MAX=30
