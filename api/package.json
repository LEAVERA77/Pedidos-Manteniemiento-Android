{
  "name": "Nexxo-api",
  "version": "1.0.0",
  "description": "API Nexxo con JWT, Neon y Cloudinary",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "emulator": "node run-emulator.js",
    "evolution:up": "docker compose -f ../docker-compose.evolution.yml up -d",
    "evolution:down": "docker compose -f ../docker-compose.evolution.yml down",
    "evolution:logs": "docker compose -f ../docker-compose.evolution.yml logs -f",
    "evolution:reset": "docker compose -f ../docker-compose.evolution.yml down -v && docker compose -f ../docker-compose.evolution.yml up -d",
    "evolution:qr": "node scripts/evolution-qr.js",
    "waha:up": "docker compose --env-file ../compose.waha.env -f ../docker-compose.waha.yml up -d",
    "waha:down": "docker compose --env-file ../compose.waha.env -f ../docker-compose.waha.yml down",
    "waha:logs": "docker logs waha --tail 50 -f",
    "waha:reset": "docker compose --env-file ../compose.waha.env -f ../docker-compose.waha.yml down -v && docker compose --env-file ../compose.waha.env -f ../docker-compose.waha.yml up -d",
    "waha:qr": "node scripts/waha-qr.js",
    "waha:pair": "node scripts/waha-pair.js",
    "geocode:padron-lote": "node scripts/geocodificarPadronLote.mjs",
    "geocode:padron": "node scripts/geocodificarPadron.js",
    "enriquecer:excel-padron": "node scripts/enriquecerPadronDesdeExcel.mjs",
    "exportar:padron-enriquecido": "node scripts/exportarPadronEnriquecidoExcel.mjs",
    "geocodificar:excel-socios": "node scripts/geocodificarExcelSocios.mjs",
    "generar:demo-socios-nominatim-verificado": "node scripts/generarSociosDemo300Nominatim.mjs",
    "generar:excel-cerrito-300": "node scripts/generarSociosCerrito300Nominatim.mjs",
    "preload:street-geometries": "node scripts/preload-street-geometries.mjs",
    "generar:localidades-ar": "node scripts/generate-localidades-argentinas-sql.mjs",
    "normalize:socios-telefonos": "node scripts/normalizeSociosCatalogoTelefonos.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.13.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@whatsapp-cloudapi/emulator": "^4.2.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  }
}
