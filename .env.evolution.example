# Copiá este archivo a .env.evolution en la raíz del repo (no commitees secretos reales).
# Uso: docker compose --env-file .env.evolution -f docker-compose.evolution.yml up -d
# Desde api/: docker compose --env-file ../.env.evolution -f ../docker-compose.evolution.yml up -d

EVOLUTION_DB_USER=evolution
EVOLUTION_DB_PASSWORD=evolution123
EVOLUTION_DB_NAME=evolution
EVOLUTION_API_KEY=gestornova-evolution-2026

# Imagen Docker (opcional). Si el QR sigue vacío: evoapicloud/evolution-api:v2.3.7
# EVOLUTION_IMAGE=atendai/evolution-api:latest

# URL pública/base que usa Evolution para enlaces internos (manager en el mismo PC).
# EVOLUTION_SERVER_URL=http://localhost:8080

# Versión del cliente WhatsApp (Baileys). Si el QR no aparece, copiá la de WhatsApp → Ajustes → Ayuda.
CONFIG_SESSION_PHONE_VERSION=2.3000.1028450369
