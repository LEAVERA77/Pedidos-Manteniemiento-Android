# Copiá este archivo a keystore.properties en la raíz del repo (mismo nivel que settings.gradle.kts).
# keystore.properties está en .gitignore — no subir contraseñas ni rutas sensibles al repo.
#
# storeFilePath / storeFile = ruta al **archivo** keystore (no a la carpeta sola).
#
# Muy común en Windows: carpeta `C:\Users\tu_usuario\keystore\` y dentro el archivo `keystore` sin extensión.
#   → storeFilePath=C:/Users/tu_usuario/keystore/keystore   (¡dos veces "keystore" en la ruta!)
#
# Otros ejemplos:
#   C:/Users/tu_usuario/mis-claves/release.jks
#
# storeFilePath — preferido
# storeFile     — alias compatible

storeFilePath=C:/Users/tu_usuario/keystore/keystore
storePassword=
keyAlias=
keyPassword=
