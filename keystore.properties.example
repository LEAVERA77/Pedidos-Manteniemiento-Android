# Copiá este archivo a keystore.properties en la raíz del repo (mismo nivel que settings.gradle.kts).
# keystore.properties está en .gitignore — no subir contraseñas al repo.
#
# Recomendado (Windows): carpeta fuera de OneDrive, p. ej. C:\Keystore\, con el archivo del store dentro.
#   storeFilePath=C:/Keystore/keystore
#   (o C:/Keystore/mi-app-release.jks si renombraste el archivo)
#
# storeFilePath — preferido
# storeFile     — alias compatible

storeFilePath=C:/Keystore/keystore
storePassword=
keyAlias=
keyPassword=
