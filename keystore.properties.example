# Copiá este archivo a keystore.properties en la raíz del repo (mismo nivel que settings.gradle.kts).
# keystore.properties está en .gitignore — no subir contraseñas ni rutas sensibles al repo.
#
# Ruta al archivo keystore (absoluta con / recomendado):
#   storeFilePath — preferido si el archivo no tiene extensión (ej. C:/Users/tu_usuario/keystore)
#   storeFile     — alias compatible (ej. C:/Users/tu_usuario/keystore/mi-release.jks)

storeFilePath=C:/Users/tu_usuario/keystore
storePassword=
keyAlias=
keyPassword=
