# Copiá este archivo a keystore.properties en la raíz del repo (mismo nivel que settings.gradle.kts).
# keystore.properties está en .gitignore — no subir contraseñas ni rutas sensibles al repo.
#
# storeFilePath / storeFile = ruta al **archivo** keystore (no a una carpeta contenedora sola).
#
# Ejemplos:
#   Archivo sin extensión bajo tu usuario:
#     C:/Users/tu_usuario/keystore
#   Archivo .jks en una carpeta:
#     C:/Users/tu_usuario/mis-claves/release.jks
#   Carpeta "keystore" y dentro archivo "keystore":
#     C:/Users/tu_usuario/keystore/keystore
#
# storeFilePath — preferido
# storeFile     — alias compatible

storeFilePath=C:/Users/tu_usuario/keystore
storePassword=
keyAlias=
keyPassword=
