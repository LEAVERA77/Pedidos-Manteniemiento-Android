# Copiá este archivo a keystore.properties en la raíz del repo (mismo nivel que settings.gradle.kts).
# keystore.properties está en .gitignore — no subir contraseñas ni rutas sensibles al repo.
#
# storeFile: ruta absoluta recomendada (barras /), p. ej.:
#   C:/Users/tu_usuario/keystore/mi-release.jks
# O ruta relativa al raíz del proyecto Android.

storeFile=C:/Users/tu_usuario/keystore/mi-release.jks
storePassword=
keyAlias=
keyPassword=
