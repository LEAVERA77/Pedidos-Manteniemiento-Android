<?xml version="1.0" encoding="utf-8"?>
<!--
    Rutas donde la app puede crear archivos temporales para compartir
    con la camara del sistema via FileProvider.
    Va en: app/src/main/res/xml/file_provider_paths.xml
-->
<paths>
    <external-files-path name="external_files" path="." />
    <external-files-path name="pictures" path="Pictures/" />
    <external-path name="public_downloads" path="Download/" />
    <!-- Exports en Descargas/GestorNova (+ legado Nexxo) -->
    <external-path name="GestorNova_exports" path="Download/GestorNova" />
    <external-path name="Nexxo_exports_legacy" path="Download/Nexxo" />
    <files-path name="internal_files" path="." />
    <!-- APK OTA copiado desde content:// del DownloadManager (Android 10+) -->
    <cache-path name="gn_apk_cache" path="apk_updates/" />
    <!-- Imágenes temporales para compartir desde el visor de fotos -->
    <cache-path name="shared_images" path="shared_images/" />
</paths>
